```gitignore
# Dependencies
node_modules/
.julia/
zig-cache/

# Build artifacts
dist/
build/
target/
out/

# Python specific
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.venv/
.env
.env.local
.env.*

# Compiled files
*.o
*.obj
*.so
*.a
*.dll
*.exe
*.out

# Logs and temp files
*.log
*.tmp
*.swp
*.swo

# Coverage reports
coverage/
htmlcov/
.coverage

# Editors
.vscode/
.idea/
*.swp
*.swo

# System files
.DS_Store
Thumbs.db

# Cache directories
.mypy_cache/
.pytest_cache/
.gradle/
```